{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "steps": {
    "playwright": {
      "inputs": [{ "step": "install" }],
      "commands": ["/app/.venv/bin/python -m playwright install --with-deps chromium"]
    }
  },
  "deploy": {
    "inputs": [{ "step": "playwright" }],
    "startCommand": "/app/.venv/bin/python -m uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000}"
  }
}